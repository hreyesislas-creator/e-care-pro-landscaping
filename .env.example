# Base URL used for canonical tags, sitemap, and structured data.
# Set this in production (e.g. https://www.ecareprolandscaping.com).
NEXT_PUBLIC_SITE_URL=https://www.ecareprolandscaping.com

# Optional: forward estimate-form leads to a CRM / automation webhook (Zapier, Make, n8n, etc.)
# If unset, leads are logged server-side. Wire email/CRM in app/api/estimate/route.ts.
LEAD_WEBHOOK_URL=
