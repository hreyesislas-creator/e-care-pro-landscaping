# Base URL used for canonical tags, sitemap, and structured data.
# Set this in production (e.g. https://www.ecareprolandscaping.com).
NEXT_PUBLIC_SITE_URL=https://www.ecareprolandscaping.com

# --- Estimate form email delivery (Resend) ---
# Required to actually send estimate-request emails. Get a key at https://resend.com.
RESEND_API_KEY=

# Optional. Recipient for estimate requests. Defaults to site.email (guillermo71m@gmail.com).
LEAD_TO_EMAIL=guillermo71m@gmail.com

# Optional. Verified sender address. Until you verify your own domain in Resend,
# you can use the shared test sender below (only delivers to your Resend account email).
LEAD_FROM_EMAIL=E-Care Pro Landscaping <onboarding@resend.dev>

# Optional: also forward estimate-form leads to a CRM / automation webhook (Zapier, Make, n8n, etc.)
# If unset, leads are logged server-side.
LEAD_WEBHOOK_URL=
